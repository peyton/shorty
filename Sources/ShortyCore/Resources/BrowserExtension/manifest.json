{
  "manifest_version": 3,
  "name": "Shorty – Web App Bridge",
  "version": "1.0.0",
  "description": "Reports the current web app domain to Shorty for context-aware keyboard shortcuts.",
  "permissions": [
    "activeTab",
    "nativeMessaging"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
