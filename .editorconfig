root = true

[*]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 2
insert_final_newline = true
trim_trailing_whitespace = true

[*.{py,pyi}]
indent_size = 4

[*.{md,markdown}]
trim_trailing_whitespace = false

[*.{sh,bash,zsh}]
binary_next_line = false
function_next_line = false
keep_padding = false
space_redirects = false
switch_case_indent = false
