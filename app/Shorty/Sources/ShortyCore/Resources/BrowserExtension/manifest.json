{
  "manifest_version": 3,
  "name": "Shorty – Web App Bridge",
  "version": "1.0.0",
  "description": "Reports the current web app domain to Shorty for context-aware keyboard shortcuts.",
  "homepage_url": "https://github.com/peyton/shorty",
  "permissions": ["activeTab", "nativeMessaging", "tabs"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "*://calendar.google.com/*",
        "*://chatgpt.com/*",
        "*://*.chatgpt.com/*",
        "*://claude.ai/*",
        "*://*.claude.ai/*",
        "*://docs.google.com/*",
        "*://drive.google.com/*",
        "*://figma.com/*",
        "*://*.figma.com/*",
        "*://github.com/*",
        "*://*.github.com/*",
        "*://linear.app/*",
        "*://*.linear.app/*",
        "*://mail.google.com/*",
        "*://meet.google.com/*",
        "*://notion.so/*",
        "*://*.notion.so/*",
        "*://sheets.google.com/*",
        "*://slack.com/*",
        "*://*.slack.com/*",
        "*://slides.google.com/*",
        "*://whatsapp.com/*",
        "*://*.whatsapp.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
